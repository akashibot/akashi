generator drizzle {
  provider = "prisma-generator-drizzle"
  output   = "../src/tables"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id     String   @id 
  tokens Int      @default(200)

  tags Tag[]

  @@map("users")
}


model Guild {
  id   String @id
  tags Tag[]

  owsChannel String? @map("ows_channel")

  @@map("guilds")
}

model Tag {
  name    String @id
  guildId  String
  userId String

  content String
  uses    Int @default(0)

  guild  Guild? @relation(fields: [guildId], references: [id])
  author User @relation(fields: [userId], references: [id])

  @@index([guildId])
  @@index([userId])
  @@map("tags")
}
