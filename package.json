{
	"name": "akashi",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"dev": "turbo dev",
		"lint": "turbo lint",
		"check": "biome check --unsafe --fix --staged \"**/*.{ts,tsx,md}\"",
		"bot": "pnpm --filter bot",
		"ipx": "pnpm --filter ipx",
		"db": "pnpm --filter @akashi/db",
		"parser": "pnpm --filter @akashi/parser",
		"illumi": "pnpm --filter illumi",
		"sato": "pnpm --filter sato",
		"vault": "pnpm --filter vault"
	},
	"devDependencies": {
		"@akashi/typescript-config": "workspace:*",
		"@biomejs/biome": "1.8.0",
		"turbo": "^2.0.3"
	},
	"packageManager": "pnpm@9.1.3",
	"engines": {
		"node": ">=20"
	}
}
