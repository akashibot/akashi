{
	"name": "akashi",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"dev": "turbo dev",
		"lint": "turbo lint",
		"check": "biome check --apply-unsafe --staged \"**/*.{ts,tsx,md}\"",
		"bot": "pnpm --filter bot",
		"ipx": "pnpm --filter ipx",
		"memge": "pnpm --filter memge",
		"db": "pnpm --filter @akashi/db"
	},
	"devDependencies": {
		"@biomejs/biome": "1.7.2",
		"@akashi/typescript-config": "workspace:*",
		"turbo": "latest"
	},
	"packageManager": "pnpm@9.1.1",
	"engines": {
		"node": ">=20"
	}
}
